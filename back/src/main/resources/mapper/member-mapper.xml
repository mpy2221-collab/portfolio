<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="kr.or.movie.member.model.dao.MemberDao">
    <select id="idCheck" resultType="member">
        SELECT * FROM member WHERE member_id = #{memberId}
    </select>

    <select id="nicknameCheck" resultType="member">
        SELECT * FROM member WHERE member_nickname = #{memberNickname}
    </select>

    <select id="emailCheck" resultType="member">
        SELECT * FROM member WHERE member_email = #{memberEmail}
    </select>

    <insert id="insertMember" parameterType="member">
        insert into member values(
            #{memberId},
            #{memberPw},
            #{memberNickname},
            #{memberPhone},
            #{memberEmail},
            2,
            sysdate,
            #{memberProfileImg}
        )
    </insert>

    <select id="findId" resultType="string">
        SELECT member_id FROM member WHERE member_email = #{memberEmail}
    </select>

    <update id="updatePwMember" parameterType="member">
        UPDATE member SET member_pw = #{memberPw} WHERE member_id = #{memberId}
    </update>

    <select id="selectMemberByEmailAndId" resultType="member">
        SELECT * FROM member WHERE member_email = #{memberEmail} AND member_id = #{memberId}
    </select>

    <select id="selectMemberById" resultType="member">
        SELECT * FROM member WHERE member_id = #{memberId}
    </select>

    <update id="updateMemberInfo" parameterType="member">
        UPDATE member SET member_nickname = #{memberNickname}, member_profile_img = #{memberProfileImg} WHERE member_id = #{memberId}
    </update>

    <select id="selectMemberProfileImg" resultType="string">
        SELECT member_profile_img 
        FROM member 
        WHERE member_id = #{memberId}
    </select>


</mapper>
