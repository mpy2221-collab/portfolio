**도입 후**: Interceptor에서 중앙화 + @RequestAttribute 사용

```sql
// LoginInterceptor.java
@Override
public boolean preHandle(HttpServletRequest request, 
        HttpServletResponse response, Object handler) throws Exception {
    
    // 헤더에서 토큰 추출
    String auth = request.getHeader(HttpHeaders.AUTHORIZATION);
    System.out.println("헤더에서 꺼낸 정보 : "+auth);
    
    // 1. 인증 토큰이 없거나 형식이 잘못된 경우
    if(auth == null || auth.indexOf("null") != -1 || !auth.startsWith("Bearer ")) {
        System.out.println("인증이 없거나, 잘못된경우");
        return false;
    }
    
    // 2. 토큰 만료 체크
    String token = auth.split(" ")[1];
    if(jwtUtil.isExpired(token)) {
        System.out.println("인증시간이 만료된 경우");
        return false;
    }
    
    // 3. 정상 인증 → memberId 추출 후 request에 저장
    String memberId = jwtUtil.getMemberId(token);
    request.setAttribute("memberId", memberId);
    return true;
}

// BoardReviewController.java
@PostMapping("/board/review")
public ResponseEntity<ResponseDTO> writeReview(
    @RequestBody BoardReview boardReview,
    @RequestAttribute String memberId  // Interceptor가 request에 저장한 값을 Spring이 자동으로 주입
) {
    boardReview.setBoardReviewMemberId(memberId);
    int result = boardReviewService.insertBoardReview(boardReview);
    // ...
}

