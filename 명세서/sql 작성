-- ============================================
-- 시퀀스 생성
-- ============================================

-- 심플 리뷰 시퀀스
CREATE SEQUENCE simple_review_seq
START WITH 1
INCREMENT BY 1
NOCACHE;

-- 유저픽 영화 시퀀스
CREATE SEQUENCE userpick_movie_seq
START WITH 1
INCREMENT BY 1
NOCACHE;

-- 유저픽 영화 장르 시퀀스
CREATE SEQUENCE userpick_genre_seq
START WITH 1
INCREMENT BY 1
NOCACHE;

-- 게시글 리뷰 추천 시퀀스
CREATE SEQUENCE board_like_seq
START WITH 1
INCREMENT BY 1
NOCACHE;

-- 게시글 리뷰 파일 시퀀스
CREATE SEQUENCE board_file_seq
START WITH 1
INCREMENT BY 1
NOCACHE;

-- 댓글 시퀀스
CREATE SEQUENCE comment_tbl_seq
START WITH 1
INCREMENT BY 1
NOCACHE;

-- ============================================
-- 테이블 생성
-- ============================================

-- 회원 테이블 생성
CREATE TABLE member (
    member_id VARCHAR2(30) NOT NULL,
    member_pw CHAR(60) NOT NULL,
    member_nickname VARCHAR2(20) NOT NULL,
    member_phone CHAR(13) NOT NULL,
    member_email VARCHAR2(30) NOT NULL,
    member_type NUMBER(1) NOT NULL,
    member_enroll_date DATE DEFAULT SYSDATE NOT NULL,
    member_profile_img VARCHAR2(500) NULL,
    
    -- 기본키 제약조건
    CONSTRAINT pk_member PRIMARY KEY (member_id),
    
    -- 유니크 제약조건
    CONSTRAINT uk_member_nickname UNIQUE (member_nickname),
    CONSTRAINT uk_member_email UNIQUE (member_email),
    
    -- 체크 제약조건 (회원 유형: 1=관리자, 2=일반회원, 3=정지회원)
    CONSTRAINT ck_member_type CHECK (member_type IN (1, 2, 3))
);

-- 심플 리뷰 테이블 생성
CREATE TABLE simple_review (
    simple_review_no NUMBER NOT NULL,
    simple_member_id VARCHAR2(30) NOT NULL,
    simple_tmdb_movie_id NUMBER NOT NULL,
    simple_review_rating NUMBER NOT NULL,
    simple_review_content VARCHAR2(500) NOT NULL,
    simple_review_date DATE DEFAULT SYSDATE NOT NULL,
    
    -- 기본키 제약조건
    CONSTRAINT pk_simple_review PRIMARY KEY (simple_review_no),
    
    -- 외래키 제약조건
    CONSTRAINT fk_simple_member FOREIGN KEY (simple_member_id) 
        REFERENCES member(member_id) ON DELETE CASCADE,
    
    -- 유니크 제약조건 (한 회원당 한 영화에 리뷰 1개만)
    CONSTRAINT uk_simple_member_movie UNIQUE (simple_member_id, simple_tmdb_movie_id),
    
    -- 체크 제약조건 (평점 범위: 1~10)
    CONSTRAINT ck_simple_rating CHECK (simple_review_rating BETWEEN 1 AND 10)
);

-- 유저픽 영화 테이블 생성
CREATE TABLE userpick_movie (
    userpick_movie_no NUMBER NOT NULL,
    userpick_tmdb_movie_id NUMBER NOT NULL,
    userpick_status NUMBER(1) DEFAULT 1 NOT NULL,
    userpick_date DATE DEFAULT SYSDATE NOT NULL,
    userpick_poster_path VARCHAR2(200) NULL,
    userpick_title VARCHAR2(200) NOT NULL,
    userpick_release_date DATE NULL,
    userpick_runtime NUMBER NULL,
    userpick_view_count NUMBER DEFAULT 0 NOT NULL,
    
    -- 기본키 제약조건
    CONSTRAINT pk_userpick_movie PRIMARY KEY (userpick_movie_no),
    
    -- 유니크 제약조건 (TMDB 영화 ID 중복 방지)
    CONSTRAINT uk_userpick_tmdb_id UNIQUE (userpick_tmdb_movie_id),
    
    -- 체크 제약조건 (상태: 1=활성, 2=비활성)
    CONSTRAINT ck_userpick_status CHECK (userpick_status IN (1, 2))
);

-- 유저픽 영화 장르 테이블 생성
CREATE TABLE userpick_genre (
    userpick_genre_no NUMBER NOT NULL,
    userpick_genre_movie_no NUMBER NOT NULL,
    userpick_genre_id NUMBER NOT NULL,
    userpick_genre_name VARCHAR2(50) NOT NULL,
    
    -- 기본키 제약조건
    CONSTRAINT pk_userpick_genre PRIMARY KEY (userpick_genre_no),
    
    -- 외래키 제약조건
    CONSTRAINT fk_userpick_genre_movie FOREIGN KEY (userpick_genre_movie_no) 
        REFERENCES userpick_movie(userpick_movie_no) ON DELETE CASCADE,
    
    -- 유니크 제약조건 (한 영화에 같은 장르 중복 방지)
    CONSTRAINT uk_userpick_genre_movie UNIQUE (userpick_genre_movie_no, userpick_genre_id)
);

-- 게시글 리뷰 테이블 생성
CREATE TABLE board_review (
    board_review_no NUMBER NOT NULL,
    board_member_id VARCHAR2(30) NOT NULL,
    board_tmdb_movie_id NUMBER NOT NULL,
    board_review_title VARCHAR2(200) NOT NULL,
    board_review_content VARCHAR2(2000) NOT NULL,
    board_review_rating NUMBER NOT NULL,
    board_review_date DATE DEFAULT SYSDATE NOT NULL,
    board_review_status NUMBER(1) DEFAULT 1 NOT NULL,
    board_view_count NUMBER DEFAULT 0 NOT NULL,
    
    -- 기본키 제약조건
    CONSTRAINT pk_board_review PRIMARY KEY (board_review_no),
    
    -- 외래키 제약조건
    CONSTRAINT fk_board_member FOREIGN KEY (board_member_id) 
        REFERENCES member(member_id) ON DELETE CASCADE,
    
    -- 유니크 제약조건 (한 회원당 한 영화에 리뷰 1개만)
    CONSTRAINT uk_board_member_movie UNIQUE (board_member_id, board_tmdb_movie_id),
    
    -- 체크 제약조건 (평점 범위: 1~10)
    CONSTRAINT ck_board_rating CHECK (board_review_rating BETWEEN 1 AND 10)
);

-- 게시글 리뷰 추천 테이블 생성
CREATE TABLE board_like (
    board_like_no NUMBER NOT NULL,
    board_like_review_no NUMBER NOT NULL,
    board_like_member_id VARCHAR2(30) NOT NULL,
    board_like_date DATE DEFAULT SYSDATE NOT NULL,
    
    -- 기본키 제약조건
    CONSTRAINT pk_board_like PRIMARY KEY (board_like_no),
    
    -- 외래키 제약조건
    CONSTRAINT fk_board_like_review FOREIGN KEY (board_like_review_no) 
        REFERENCES board_review(board_review_no) ON DELETE CASCADE,
    CONSTRAINT fk_board_like_member FOREIGN KEY (board_like_member_id) 
        REFERENCES member(member_id) ON DELETE CASCADE,
    
    -- 유니크 제약조건 (한 회원당 한 게시글에 추천 1개만)
    CONSTRAINT uk_board_like_review_member UNIQUE (board_like_review_no, board_like_member_id)
);

-- 게시글 리뷰 파일 테이블 생성
CREATE TABLE board_file (
    board_file_no NUMBER NOT NULL,
    board_file_review_no NUMBER NOT NULL,
    board_filename VARCHAR2(255) NOT NULL,
    board_filepath VARCHAR2(255) NOT NULL,
    
    -- 기본키 제약조건
    CONSTRAINT pk_board_file PRIMARY KEY (board_file_no),
    
    -- 외래키 제약조건
    CONSTRAINT fk_board_file_review FOREIGN KEY (board_file_review_no) 
        REFERENCES board_review(board_review_no) ON DELETE CASCADE
);

-- 댓글 테이블 생성 (공용)
CREATE TABLE comment_tbl (
    comment_no NUMBER NOT NULL,
    comment_type VARCHAR2(20) NOT NULL,
    comment_userpick_no NUMBER NULL,
    comment_board_no NUMBER NULL,
    comment_member_id VARCHAR2(30) NOT NULL,
    comment_content VARCHAR2(500) NOT NULL,
    comment_date DATE DEFAULT SYSDATE NOT NULL,
    comment_parent_no NUMBER NULL,
    
    -- 기본키 제약조건
    CONSTRAINT pk_comment_tbl PRIMARY KEY (comment_no),
    
    -- 외래키 제약조건
    CONSTRAINT fk_comment_userpick FOREIGN KEY (comment_userpick_no) 
        REFERENCES userpick_movie(userpick_movie_no) ON DELETE CASCADE,
    CONSTRAINT fk_comment_board FOREIGN KEY (comment_board_no) 
        REFERENCES board_review(board_review_no) ON DELETE CASCADE,
    CONSTRAINT fk_comment_member FOREIGN KEY (comment_member_id) 
        REFERENCES member(member_id) ON DELETE CASCADE,
    CONSTRAINT fk_comment_parent FOREIGN KEY (comment_parent_no) 
        REFERENCES comment_tbl(comment_no) ON DELETE CASCADE,
    
    -- 체크 제약조건 (댓글 유형: 'userpick' 또는 'board')
    CONSTRAINT ck_comment_type CHECK (comment_type IN ('userpick', 'board')),
    
    -- 체크 제약조건 (댓글 유형에 따른 필수 필드 검증)
    CONSTRAINT ck_comment_check CHECK (
        (comment_type = 'userpick' AND comment_userpick_no IS NOT NULL AND comment_board_no IS NULL)
        OR 
        (comment_type = 'board' AND comment_board_no IS NOT NULL AND comment_userpick_no IS NULL)
    )
);
